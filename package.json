{
  "name": "micro-app-adapter",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky",
    "lint": "eslint packages",
    "lint:check": "eslint packages",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json,md}\"",
    "build": "pnpm -r --stream build",
    "build:react-vite": "pnpm --filter @micro-app-adapter/react-vite build",
    "build:react-webpack": "pnpm --filter @micro-app-adapter/react-webpack build",
    "build:vue3-vite": "pnpm --filter @micro-app-adapter/vue3-vite build",
    "build:vue3-webpack": "pnpm --filter @micro-app-adapter/vue3-webpack build",
    "clean": "pnpm -r exec rimraf dist",
    "clean:react-vite": "pnpm --filter @micro-app-adapter/react-vite exec rimraf dist",
    "clean:react-webpack": "pnpm --filter @micro-app-adapter/react-webpack exec rimraf dist",
    "clean:vue3-vite": "pnpm --filter @micro-app-adapter/vue3-vite exec rimraf dist",
    "clean:vue3-webpack": "pnpm --filter @micro-app-adapter/vue3-webpack exec rimraf dist",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "version": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm run build && changeset publish",
    "release:patch": "pnpm run build && pnpm --filter \"./packages/*\" -r exec -- npm version patch --no-git-tag-version && pnpm --filter \"./packages/*\" -r publish --access public --ignore-scripts",
    "release:minor": "pnpm run build && pnpm --filter \"./packages/*\" -r exec -- npm version minor --no-git-tag-version && pnpm --filter \"./packages/*\" -r publish --access public --ignore-scripts",
    "release:major": "pnpm run build && pnpm --filter \"./packages/*\" -r exec -- npm version major --no-git-tag-version && pnpm --filter \"./packages/*\" -r publish --access public --ignore-scripts",
    "version:patch": "pnpm --filter \"./packages/*\" -r exec -- npm version patch --no-git-tag-version",
    "version:minor": "pnpm --filter \"./packages/*\" -r exec -- npm version minor --no-git-tag-version",
    "version:major": "pnpm --filter \"./packages/*\" -r exec -- npm version major --no-git-tag-version",
    "publish:all": "pnpm --filter \"./packages/*\" -r publish --access public --ignore-scripts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.4.1"
}
